{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/v2/crates/tauri-config-schema/schema.json",
  "productName": "GlideKit",
  "version": "0.0.0",
  "identifier": "com.glidekit.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "GlideKit",
        "width": 820,
        "height": 920,
        "minWidth": 600,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsi",
        "installMode": "currentUser",
        "compression": "lzma"
      }
    }
  }
}
